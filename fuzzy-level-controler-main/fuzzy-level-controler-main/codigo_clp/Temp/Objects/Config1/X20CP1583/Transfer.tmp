<?xml version="1.0" encoding="utf-8"?>
<?AutomationStudio Version=3.0?>
<Transfer xmlns="http://br-automation.co.at/AS/Transfer">
  <AppMod Name="&lt;Default&gt;" Img="AppModule.ico">
    <Cat Name="Cyclic #4" Img="Cyclic.ico">
      <Mod Name="MiguelProj" Img="Task.ico" Stat="NotOnTarget" Act="Download" Vars="Init">
      </Mod>
      <Mod Name="ProjetoIA" Img="Task.ico" Stat="OnTargetOnly" Act="Delete" Vars="Init">
      </Mod>
    </Cat>
    <Cat Name="Binary Objects" Img="Binaries.ico">
      <Mod Name="OpcUaMap" Img="Binary.ico" Stat="Different" Act="Download">
      </Mod>
    </Cat>
    <Cat Name="Library Objects" Img="Libraries.ico">
      <Mod Name="Runtime" Img="files\IEC.lby.ico" Stat="Equal" Act="Ignore" Chng="TRUE">
      </Mod>
      <Mod Name="brsystem" Img="files\IEC.lby.ico" Stat="Different" Act="Download" Chng="TRUE">
      </Mod>
      <Mod Name="sys_lib" Img="files\IEC.lby.ico" Stat="Different" Act="Download" Chng="TRUE">
      </Mod>
      <Mod Name="astime" Img="files\IEC.lby.ico" Stat="Different" Act="Download" Chng="FALSE">
        <Details>
          <Det Desc="Accessing module asieccon deleted and retransferred because of dependencies" Img="Warning.ico" />
        </Details>
      </Mod>
      <Mod Name="asieccon" Img="files\IEC.lby.ico" Stat="Different" Act="Delete" Chng="TRUE">
        <Details>
          <Det Desc="Deleted and retransferred because of dependency to module astime" Img="Warning.ico" />
        </Details>
      </Mod>
      <Mod Name="LoopConR" Img="files\IEC.lby.ico" Stat="Equal" Act="Ignore" Chng="TRUE">
      </Mod>
      <Mod Name="standard" Img="files\IEC.lby.ico" Stat="Different" Act="Download" Chng="TRUE">
      </Mod>
    </Cat>
    <Cat Name="Configuration Objects" Img="Configuration.ico">
      <Mod Name="ashwd" Img="files\BR.ico" Stat="Different" Act="Download" Res="Warm">
      </Mod>
      <Mod Name="asfw" Img="files\BR.ico" Stat="Different" Act="Download" Res="Warm">
      </Mod>
      <Mod Name="arconfig" Img="files\rtc.ico" Stat="Different" Act="Download" Res="Warm">
      </Mod>
      <Mod Name="sysconf" Img="files\BR.ico" Stat="Different" Act="Download" Res="Warm">
      </Mod>
      <Mod Name="iomap" Img="files\iom.ico" Stat="Different" Act="Download">
      </Mod>
    </Cat>
  </AppMod>
</Transfer>
